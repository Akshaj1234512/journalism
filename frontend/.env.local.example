# The Red Room — frontend environment variables.
# Copy this file to `.env.local` and fill in the real values.
# In production these are set in the Vercel dashboard, not in a file.

# URL of the FastAPI backend (Hugging Face Space). No trailing slash.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Public URL of this frontend. Used for share images / OG tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (accounts + login) ---
# Both values come from the Supabase dashboard:
#   Project Settings -> API
# The anon key is safe to expose to the browser; it is not a secret.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
